(F,ap,aq){
var l=(%_ToObject(this));
var m=(%_ToLength(l.length));
var t=(ap===(void 0))?0:(%_ToInteger(ap));
var aq=(aq===(void 0))?m:(%_ToInteger(aq));
if(t<0){
t+=m;
if(t<0)t=0;
}else{
if(t>m)t=m;
}
if(aq<0){
aq+=m;
if(aq<0)aq=0;
}else{
if(aq>m)aq=m;
}
for(;t<aq;t++)
l[t]=F;
return l;
}}

